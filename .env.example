# Luna Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# WALLET & API CONFIGURATION (REQUIRED)
# ============================================

# Polygon wallet private key (with 0x prefix)
# WARNING: Keep this secret! Never commit to git!
POLY_PRIVATE_KEY=0x...

# Polymarket API credentials (get from https://polymarket.com)
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_PASSPHRASE=your_passphrase_here

# ============================================
# TRADING CONFIGURATION
# ============================================

# Starting capital in USD
INITIAL_CAPITAL=5.0

# Starting phase (1-4)
# 1 = Safety First (5% max position)
# 2 = Steady Growth (10% max position)
# 3 = Confident Expansion (15% max position)
# 4 = Aggressive Compounding (25% max position)
START_PHASE=1

# Risk management
MAX_DAILY_LOSS=0.20  # 20% drawdown limit
MIN_LIQUIDITY=10000  # Minimum $10k market liquidity

# Trading parameters
CHECK_INTERVAL_MINUTES=5  # How often to check markets
MAX_POSITION_USD=0.25     # Hard cap per trade ($)

# ============================================
# BOT CONFIGURATION
# ============================================

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# Feature flags
MOCK_MODE=true  # Set to false when ready to trade live
DRY_RUN=true    # Set to false to enable actual trading
PAPER_TRADING=true  # Set to true for paper trading (simulation without real money)

# ============================================
# NOTIFICATION CONFIGURATION (OPTIONAL)
# ============================================

# Telegram alerts for daily reports
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get chat ID from @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here
