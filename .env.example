# Luna Polymarket Bot - Environment Variables

# Trading Mode
PAPER_TRADING=true
INITIAL_CAPITAL=5.0
START_PHASE=1

# API Keys (for live mode)
POLY_PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# LLM Router
LLM_MODEL=qwen/qwen3.6-plus:free
LLM_PRO_MODEL=qwen/qwen3.5-flash
OPENROUTER_API_KEY=your_openrouter_key

# Modules
ENABLE_LLM=true
ENABLE_NEWS=true
ENABLE_COMPUNDING=true
ENABLE_MARKET_FILTER=true
ENABLE_ORDERBOOK=true
ENABLE_CORRELATION=true
ENABLE_EVOLUTION=true
ENABLE_DASHBOARD=true
DASHBOARD_PORT=8080

# Risk
MAX_DAILY_LOSS=0.20
KELLY_FRACTION=0.25
MIN_PROFIT_OFFLOAD=0.10
MAX_DURATION_HOURS=168
MIN_LIQUIDITY=5000
MIN_VOLUME_24H=1000
MAX_SPREAD_BPS=200
